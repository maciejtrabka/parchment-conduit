{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/pc-api/:path*",
      "destination": "https://conduit.productionready.io/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/pc-api/:path*",
      "headers": [
        {
          "key": "x-vercel-enable-rewrite-caching",
          "value": "0"
        }
      ]
    }
  ]
}
